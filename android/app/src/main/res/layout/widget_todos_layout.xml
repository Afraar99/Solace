<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_todos_body_bg">

    <LinearLayout
        android:id="@+id/todo_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Black header -->
        <LinearLayout
            android:id="@+id/todo_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_todos_header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="6dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/todo_header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Solace Tasks · Today"
                android:textColor="#FFFF8A00"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/todo_header_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/todo_add_button"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="+"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

            <ProgressBar
                android:id="@+id/todo_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_todo_progress" />

            <TextView
                android:id="@+id/todo_progress_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="0 OF 0 DONE"
                android:textAllCaps="true"
                android:textColor="#FFFF8A00"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <!-- Notebook list -->
            <LinearLayout
                android:id="@+id/todo_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Row template repeated 5x -->
                <LinearLayout
                    android:id="@+id/todo_row_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_todo_open_row_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="7dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/todo_check_1"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/widget_todo_checkbox_empty"
                        android:gravity="center"
                        android:text=""
                        android:textColor="#FFE53935"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/todo_title_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF5F5F5"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/todo_line_1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_todo_line"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/todo_row_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_todo_open_row_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="7dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/todo_check_2"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/widget_todo_checkbox_empty"
                        android:gravity="center"
                        android:text=""
                        android:textColor="#FFE53935"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/todo_title_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF5F5F5"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/todo_line_2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_todo_line"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/todo_row_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_todo_open_row_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="7dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/todo_check_3"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/widget_todo_checkbox_empty"
                        android:gravity="center"
                        android:text=""
                        android:textColor="#FFE53935"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/todo_title_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF5F5F5"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/todo_line_3"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_todo_line"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/todo_row_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_todo_open_row_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="7dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/todo_check_4"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/widget_todo_checkbox_empty"
                        android:gravity="center"
                        android:text=""
                        android:textColor="#FFE53935"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/todo_title_4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF5F5F5"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/todo_line_4"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_todo_line"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/todo_row_5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_todo_open_row_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="7dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/todo_check_5"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@drawable/widget_todo_checkbox_empty"
                        android:gravity="center"
                        android:text=""
                        android:textColor="#FFE53935"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/todo_title_5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="#FFF5F5F5"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/todo_celebration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/todo_celebration_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="72sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/todo_celebration_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="All clear!"
            android:textColor="#FFFF8A00"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</FrameLayout>
