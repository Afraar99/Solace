<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/breath_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <!-- Status / context -->
    <TextView
        android:id="@+id/breath_overlay_app_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="48dp"
        android:textColor="#99FFFFFF"
        android:textSize="13sp"
        tools:ignore="HardcodedText"
        tools:text="← Instagram" />

    <!-- Prompt -->
    <TextView
        android:id="@+id/breath_overlay_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="28dp"
        android:layout_marginTop="160dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="@string/breath_pause_prompt"
        android:textColor="#FFFFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/breath_overlay_phase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="28dp"
        android:layout_marginTop="220dp"
        android:layout_marginEnd="28dp"
        android:gravity="center"
        android:textColor="#B3FFFFFF"
        android:textSize="15sp"
        tools:ignore="HardcodedText"
        tools:text="Breathe in" />

    <!-- Breathing block grows from bottom -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="bottom">

        <View
            android:id="@+id/breath_overlay_block"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/overlay_breath_gradient" />
    </FrameLayout>

    <!-- Actions appear after breaths -->
    <LinearLayout
        android:id="@+id/breath_overlay_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="48dp"
        android:visibility="gone">

        <Button
            android:id="@+id/breath_overlay_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/shape_rounded_md"
            android:backgroundTint="#FFFFFFFF"
            android:text="@string/breath_pause_continue"
            android:textAllCaps="false"
            android:textColor="#FF000000"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/breath_overlay_quit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:text="@string/breath_pause_quit"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
