<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/breath_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0B0F14">

    <!-- Fill rises from bottom, sits behind copy -->
    <View
        android:id="@+id/breath_overlay_block"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:background="@drawable/overlay_breath_gradient" />

    <!-- Foreground content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="56dp"
        android:paddingEnd="28dp"
        android:paddingBottom="120dp">

        <TextView
            android:id="@+id/breath_overlay_app_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            tools:ignore="HardcodedText"
            tools:text="← Instagram" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.35" />

        <TextView
            android:id="@+id/breath_overlay_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="@string/breath_pause_prompt"
            android:textColor="#FFFFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/breath_overlay_phase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            tools:ignore="HardcodedText"
            tools:text="Breathe in…" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/breath_overlay_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="48dp"
        android:visibility="gone">

        <Button
            android:id="@+id/breath_overlay_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/shape_rounded_md"
            android:backgroundTint="#FFC23A5E"
            android:text="@string/breath_pause_continue"
            android:textAllCaps="false"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/breath_overlay_quit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:text="@string/breath_pause_quit"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
